# Cache-Control und Kompression für bessere Performance
# Apache; bei Nginx siehe Performance-Analyse-Vor-Launch.md

<IfModule mod_headers.c>
  # Statische Assets lang cachen (1 Jahr), mit Version/Query-String invalidation
  <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|webp|svg|woff2?|ttf|eot|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML kürzer cachen (1 Stunde), damit Updates sichtbar werden
  <FilesMatch "\.(html?)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# Gzip-Kompression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

# Optional: Brotli, falls mod_brotli vorhanden
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css application/javascript application/json
</IfModule>

# SEO: Canonical-URLs erzwingen (Rewrite + Redirect für World4You-Kompatibilität)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ / [R=301,L]
  RewriteRule ^267059-geschenkgutschein-vorlage\.html$ /geschenkgutschein.html [R=301,L]
</IfModule>

# Fallback wenn mod_rewrite deaktiviert ist (mod_alias)
Redirect 301 /index.html https://www.drcenik.at/
Redirect 301 /267059-geschenkgutschein-vorlage.html https://www.drcenik.at/geschenkgutschein.html

# Benutzerdefinierte 404-Seite
ErrorDocument 404 /404.html
