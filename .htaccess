# Cache-Control und Kompression für bessere Performance
# Apache; bei Nginx siehe Performance-Analyse-Vor-Launch.md
# Hinweis: Auf GitHub Pages unwirksam — Redirects über infra/cloudflare/

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # HTTPS erzwingen
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Apex → www
  RewriteCond %{HTTP_HOST} ^drcenik\.at$ [NC]
  RewriteRule ^ https://www.drcenik.at%{REQUEST_URI} [R=301,L]

  # Doppel-Slash im Pfad
  RewriteCond %{REQUEST_URI} ^(.*)/{2,}(.*)$
  RewriteRule ^ %1/%2 [R=301,L]

  # index.html → /
  RewriteRule ^index\.html$ / [R=301,L,NC]

  # Legacy Gutschein
  RewriteRule ^267059-geschenkgutschein-vorlage\.html$ /geschenkgutschein.html [R=301,L,NC]

  # Trailing Slash auf *.html
  RewriteRule ^(.+\.html)/+$ /$1 [R=301,L,NC]
</IfModule>

<IfModule mod_alias.c>
  Redirect 301 /index.html https://www.drcenik.at/
  Redirect 301 /267059-geschenkgutschein-vorlage.html https://www.drcenik.at/geschenkgutschein.html
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|webp|svg|woff2?|ttf|eot|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html?)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css application/javascript application/json
</IfModule>

ErrorDocument 404 /404.html
